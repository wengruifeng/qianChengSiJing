page {
  min-height: 100vh;
  background: #f3f6fb;
  color: #202733;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  border-radius: 8rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  text-align: center;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(18, 48, 82, 0.06);
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.muted {
  color: #8a94a3;
}

.primary {
  color: #1592f5;
}

.danger {
  color: #e85b42;
}

.btn-primary {
  height: 88rpx;
  background: #1592f5;
  color: #ffffff;
  font-size: 30rpx;
}

.btn-ghost {
  height: 72rpx;
  background: #edf6ff;
  color: #1592f5;
  font-size: 28rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 6rpx;
  background: #f0f4f8;
  color: #7d8794;
  font-size: 22rpx;
}

.price-hidden {
  color: #ee6b2f;
  font-weight: 700;
}

.form-card {
  background: #ffffff;
  border-radius: 8rpx;
  overflow: hidden;
}

.form-row {
  min-height: 104rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #eef1f4;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  width: 210rpx;
  font-size: 30rpx;
  color: #202733;
}

.form-input {
  flex: 1;
  text-align: right;
  color: #202733;
}

.admin-page {
  min-height: 100vh;
  background: #f5f6fa;
}

.admin-header {
  padding: 28rpx 28rpx 18rpx;
  background: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: #ffffff;
}

.admin-grid-item {
  min-height: 164rpx;
  padding: 22rpx 10rpx;
  border-right: 1rpx solid #eef1f4;
  border-bottom: 1rpx solid #eef1f4;
  text-align: center;
}

.admin-grid-icon {
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto 16rpx;
  border-radius: 8rpx;
  background: #26bfd0;
}
