.section-title {
  padding: 28rpx 28rpx 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.value-text {
  color: #6b7280;
}

.form-row-top {
  align-items: flex-start;
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.notice-input {
  flex: 1;
  min-height: 168rpx;
  padding-top: 6rpx;
  color: #202733;
  line-height: 1.7;
  text-align: left;
}

.upload-card {
  padding: 20rpx 28rpx 24rpx;
  border-top: 1rpx solid #f0f2f5;
}

.upload-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.small-btn {
  width: 160rpx;
  height: 64rpx;
  background: #edf6ff;
  color: #1592f5;
  font-size: 26rpx;
}

.upload-preview {
  width: 100%;
  height: 220rpx;
  margin-top: 16rpx;
  border-radius: 8rpx;
  background: #f5f7fb;
}

.upload-preview-logo {
  width: 180rpx;
  height: 180rpx;
}

.upload-preview-banner {
  height: 180rpx;
}

.upload-input {
  margin-top: 16rpx;
  text-align: left;
}

.settings-hint {
  margin-top: 20rpx;
  padding: 0 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.7;
}

.btn-primary {
  margin-top: 32rpx;
}

.btn-secondary {
  margin-top: 16rpx;
}

.submit-btn {
  width: 100%;
}

.tool-card {
  margin-top: 24rpx;
}

.tool-desc {
  padding: 0 28rpx 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}
