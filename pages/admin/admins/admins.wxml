<view class="page">
  <view class="toolbar">
    <view>
      <view class="toolbar-title">{{roleName}}列表</view>
      <view class="toolbar-sub">账号变更直接生效，仅特殊超级管理员可操作</view>
    </view>
    <button class="add-btn" bindtap="openCreate">新增</button>
  </view>

  <view class="empty" wx:if="{{loading}}">正在加载{{roleName}}...</view>
  <view class="empty" wx:elif="{{!admins.length}}">暂无{{roleName}}</view>
  <view class="card admin" wx:for="{{admins}}" wx:key="id">
    <view class="admin-main">
      <view class="admin-title">{{item.name || item.phone}}</view>
      <view class="admin-sub">{{item.phone}}<text wx:if="{{item.remark}}"> · {{item.remark}}</text></view>
    </view>
    <view class="admin-actions">
      <view class="tag" wx:if="{{item.protected}}">受保护</view>
      <view class="icon-btn" bindtap="edit" data-id="{{item.id}}">编辑</view>
      <view wx:if="{{!item.protected}}" class="icon-btn danger" bindtap="remove" data-id="{{item.id}}">删除</view>
    </view>
  </view>

  <view wx:if="{{showEditor}}" class="editor-mask" catchtap="cancelEdit">
    <view class="editor-panel" catchtap="noop">
      <view class="editor-head">
        <view class="editor-title">{{editingId ? '编辑' + roleName : '新增' + roleName}}</view>
        <view class="editor-close" bindtap="cancelEdit">关闭</view>
      </view>
      <view class="form-card editor-form">
        <view class="form-row">
          <view class="form-label">手机号</view>
          <input class="form-input" type="number" value="{{phone}}" bindinput="onPhone" disabled="{{editingProtected}}" placeholder="请输入{{roleName}}手机号" />
        </view>
        <view class="lock-tip" wx:if="{{editingProtected}}">受保护的特殊超级管理员不能修改手机号</view>
        <view class="form-row">
          <view class="form-label">姓名</view>
          <input class="form-input" value="{{name}}" bindinput="onName" placeholder="可选" />
        </view>
        <view class="form-row">
          <view class="form-label">备注</view>
          <input class="form-input" value="{{remark}}" bindinput="onRemark" placeholder="可选" />
        </view>
      </view>
      <view class="editor-actions">
        <button class="btn-secondary" bindtap="cancelEdit">取消</button>
        <button class="btn-primary" bindtap="submit" loading="{{submitting}}" disabled="{{submitting}}">{{submitting ? '处理中...' : (editingId ? '保存修改' : addButtonText)}}</button>
      </view>
    </view>
  </view>
</view>
