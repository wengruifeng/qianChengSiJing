<view class="page">
  <view class="form-card">
    <view class="form-row"><view class="form-label">手机号</view><input class="form-input" type="number" value="{{phone}}" bindinput="onPhone" placeholder="添加管理员手机号" /></view>
  </view>
  <button class="btn-primary" bindtap="add">添加管理员</button>
  <view class="card admin" wx:for="{{admins}}" wx:key="id">
    <view>{{item.phone}}</view>
    <view class="tag">{{item.role === 'super_admin' ? '超级管理员' : '管理员'}}</view>
  </view>
</view>
