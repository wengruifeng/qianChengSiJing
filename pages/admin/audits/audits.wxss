.tabs {
  white-space: nowrap;
  height: 88rpx;
  margin-bottom: 18rpx;
  background: #ffffff;
}

.tab {
  display: inline-block;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
  color: #6b7280;
}

.tab.active {
  color: #1592f5;
  font-weight: 700;
  border-bottom: 4rpx solid #1592f5;
}

.audit {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-pending {
  color: #d97706;
  background: #fff7ed;
}

.status-approved {
  color: #0f766e;
  background: #ecfeff;
}

.status-rejected {
  color: #b91c1c;
  background: #fef2f2;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0 10rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  color: #64748b;
  font-size: 22rpx;
}

.diff {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f7fafc;
  color: #586274;
  line-height: 1.7;
}

.reject-text {
  margin-top: 14rpx;
  color: #b91c1c;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.actions button {
  width: 150rpx;
  height: 62rpx;
  margin: 0;
}

.empty-box {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #8a94a3;
}
