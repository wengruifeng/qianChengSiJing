.tabs {
  white-space: nowrap;
  height: 88rpx;
  margin-bottom: 18rpx;
  background: #ffffff;
}

.tab {
  display: inline-block;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 28rpx;
  color: #6b7280;
}

.tab.active {
  color: #1592f5;
  font-weight: 700;
  border-bottom: 4rpx solid #1592f5;
}

.audit {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-pending {
  color: #d97706;
  background: #fff7ed;
}

.status-approved {
  color: #0f766e;
  background: #ecfeff;
}

.status-rejected {
  color: #b91c1c;
  background: #fef2f2;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0 10rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  color: #64748b;
  font-size: 22rpx;
}

.warn-pill {
  background: #fff7ed;
  color: #d97706;
}

.expand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #f7fafc;
}

.expand-text {
  color: #1592f5;
  font-size: 24rpx;
  font-weight: 600;
}

.expand-arrow {
  color: #94a3b8;
  font-size: 22rpx;
}

.diff {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f7fafc;
}

.diff-item + .diff-item {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e7edf4;
}

.diff-item-sensitive {
  background: #fffaf3;
  border-radius: 8rpx;
  padding: 12rpx;
}

.diff-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.diff-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.diff-flag {
  color: #d97706;
  font-size: 22rpx;
}

.diff-line {
  display: flex;
  gap: 18rpx;
  margin-top: 12rpx;
}

.diff-side {
  width: 92rpx;
  flex-shrink: 0;
  color: #64748b;
  font-size: 24rpx;
}

.diff-value {
  flex: 1;
  color: #334155;
  line-height: 1.7;
  word-break: break-all;
}

.diff-block {
  margin-top: 12rpx;
}

.diff-block-new {
  margin-top: 16rpx;
}

.diff-paragraph {
  margin-top: 8rpx;
  color: #334155;
  line-height: 1.8;
  white-space: pre-wrap;
}

.diff-image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}

.diff-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background: #eaf0f6;
}

.reject-text {
  margin-top: 14rpx;
  color: #b91c1c;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.actions button {
  width: 150rpx;
  height: 62rpx;
  margin: 0;
}

.empty-box {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #8a94a3;
}

.state-box,
.error-box {
  padding: 32rpx 24rpx;
  margin-bottom: 18rpx;
  text-align: center;
}

.error-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #b91c1c;
}

.error-desc {
  margin-top: 12rpx;
  color: #64748b;
  line-height: 1.6;
  word-break: break-all;
}

.retry-btn {
  width: 220rpx;
  height: 64rpx;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #1592f5;
  background: #eaf6ff;
}

.pager {
  padding: 8rpx 0 32rpx;
  text-align: center;
}

.load-more-btn {
  width: 260rpx;
  height: 68rpx;
  margin: 0 auto;
  font-size: 26rpx;
  color: #1592f5;
  background: #eaf6ff;
}

.no-more {
  color: #94a3b8;
  font-size: 24rpx;
}
