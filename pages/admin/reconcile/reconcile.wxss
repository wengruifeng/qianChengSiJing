.filters {
  padding: 10rpx 24rpx;
  margin-bottom: 20rpx;
}

.filter-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef1f4;
}

.filter-row:last-child {
  border-bottom: none;
}

.filter-label {
  font-size: 28rpx;
  color: #5b6472;
}

.filter-input {
  width: 360rpx;
  text-align: right;
  color: #1f2937;
}

.picker-value {
  color: #1f2937;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.summary-box {
  padding: 20rpx 24rpx;
}

.summary-label {
  color: #8a94a3;
  font-size: 24rpx;
}

.summary-value {
  margin-top: 10rpx;
  color: #1592f5;
  font-size: 38rpx;
  font-weight: 700;
}

.summary-box-sub .summary-value {
  font-size: 32rpx;
}

.action-panel {
  padding: 20rpx 24rpx;
  margin-bottom: 18rpx;
}

.action-panel-top {
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.selection-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a94a3;
}

.selection-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex-shrink: 0;
}

.text-action {
  font-size: 26rpx;
  color: #1592f5;
  font-weight: 600;
}

.action-buttons {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.small-btn {
  min-width: 220rpx;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}

.primary-export-btn {
  min-width: 260rpx;
}

.order-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: 700;
}

.order-head {
  gap: 16rpx;
}

.order-head-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.checkbox {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #c5d2df;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff;
}

.checkbox-active {
  border-color: #1592f5;
  background: #1592f5;
}

.checkbox-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 6rpx;
  background: #fff;
}

.goods {
  margin-top: 14rpx;
  color: #334155;
  line-height: 1.7;
}

.order-footer {
  margin-top: 18rpx;
  align-items: flex-end;
}

.price {
  color: #ef6c2f;
  font-size: 34rpx;
  font-weight: 700;
}

.inline-btn {
  width: 188rpx;
  height: 60rpx;
  font-size: 24rpx;
}

.order-actions {
  display: flex;
  gap: 12rpx;
}

.tag-pending {
  color: #d97706;
  background: #fff7ed;
}

.tag-settled {
  color: #0f766e;
  background: #ecfeff;
}

.empty-box {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #8a94a3;
}
