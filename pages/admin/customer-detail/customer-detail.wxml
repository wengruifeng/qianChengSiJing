<view class="page" wx:if="{{customer}}">
  <view class="card head">
    <view class="avatar">{{initial}}</view>
    <view>
      <view class="name">{{displayName}}</view>
      <view class="muted">{{customer.phone}} · {{statusText}}</view>
    </view>
  </view>
  <view class="card block">
    <view>所在地区：{{regionText}}</view>
    <view>详细地址：{{addressText}}</view>
    <view>备注：{{remarkText}}</view>
    <view>累计订单：{{orderCount}} 单</view>
    <view>累计采购：¥{{orderAmount}}</view>
  </view>
  <view class="card block">
    <view class="block-title">收货地址</view>
    <view class="address-item" wx:for="{{addresses}}" wx:key="id">
      <view>{{item.contactName}} {{item.phone}}</view>
      <view class="muted">{{item.region}} {{item.detail}}</view>
    </view>
    <view class="muted" wx:if="{{addresses.length === 0}}">暂无地址</view>
  </view>
  <view class="card block">
    <view class="block-title">最近订单</view>
    <view class="order-item" wx:for="{{latestOrders}}" wx:key="id">
      <view class="between">
        <view>{{item.orderNo}}</view>
        <view class="primary">¥{{item.amount}}</view>
      </view>
      <view class="muted">{{item.createdAt}}</view>
      <view class="muted">{{item.items.length}} 个品项</view>
    </view>
    <view class="muted" wx:if="{{latestOrders.length === 0}}">暂无订单</view>
  </view>
  <view class="card block">
    <view class="block-title">操作记录</view>
    <view class="muted" wx:for="{{logs}}" wx:key="id">{{item.createdAt}} {{item.summary}}</view>
    <button wx:if="{{logsHasMore}}" bindtap="loadMoreLogs" loading="{{loadingLogs}}" disabled="{{loadingLogs}}">加载更多记录</button>
  </view>
</view>
