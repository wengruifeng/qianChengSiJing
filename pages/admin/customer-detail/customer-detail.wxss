.head {
  display: flex;
  gap: 22rpx;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #1592f5;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.name {
  font-size: 34rpx;
  font-weight: 700;
}

.block {
  padding: 24rpx;
  margin-bottom: 20rpx;
  line-height: 1.9;
}

.block-title {
  font-weight: 700;
  margin-bottom: 10rpx;
}

.address-item,
.order-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef1f4;
}

.address-item:last-child,
.order-item:last-child {
  border-bottom: none;
}
