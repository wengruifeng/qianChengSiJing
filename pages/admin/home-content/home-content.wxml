<view class="page">
  <view class="form-card">
    <view class="form-row"><view class="form-label">主标题</view><input class="form-input" value="{{form.bannerTitle}}" data-key="bannerTitle" bindinput="onInput" /></view>
    <view class="form-row"><view class="form-label">滚动公告</view><input class="form-input" value="{{form.notice}}" data-key="notice" bindinput="onInput" /></view>
    <view class="form-row"><view class="form-label">首页主图</view><input class="form-input" value="{{form.heroImage}}" data-key="heroImage" bindinput="onInput" /></view>
    <view class="form-row"><view class="form-label">专题横幅</view><input class="form-input" value="{{form.topicImage}}" data-key="topicImage" bindinput="onInput" /></view>
  </view>
  <button class="btn-primary" bindtap="submit">提交审核</button>
</view>
