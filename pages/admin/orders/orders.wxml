<view class="page">
  <view class="filters">
    <input placeholder="客户/手机号/商品关键词" value="{{keyword}}" bindinput="onKeyword" />
    <picker range="{{statusOptions}}" range-key="label" bindchange="onStatus">
      <view>{{statusLabel}}</view>
    </picker>
  </view>
  <view class="card order" wx:for="{{orders}}" wx:key="id">
    <view class="between">
      <text class="order-no">{{item.orderNo}}</text>
      <text class="status-tag {{item.statusClass}}">{{item.statusText}}</text>
    </view>
    <view class="muted">{{item.customerName}} {{item.customerPhone}}</view>
    <view class="muted">{{item.createdAt}}</view>
    <view class="meta-row">
      <view class="meta-pill {{item.settlementClass}}">{{item.settlementText}}</view>
      <view class="meta-pill">共 {{item.totalQty}} 件</view>
      <view class="meta-pill">¥{{item.amount}}</view>
    </view>
    <view class="goods">{{item.goodsText}}</view>
    <view class="muted address-line">{{item.addressText}}</view>
    <view class="muted remark-line">备注：{{item.remarkText}}</view>
    <view class="between">
      <text class="price">¥{{item.amount}}</text>
      <picker data-id="{{item.id}}" range="{{nextStatuses}}" range-key="label" bindchange="changeOrderStatus">
        <button class="status-btn">改状态</button>
      </picker>
    </view>
  </view>
</view>
