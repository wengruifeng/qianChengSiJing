.status {
  padding: 34rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #1592f5, #27c0d3);
  color: #ffffff;
}

.status-title {
  font-size: 40rpx;
  font-weight: 800;
}

.status text {
  display: block;
  margin-top: 12rpx;
  opacity: 0.86;
}

.status-pills {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.status-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.block {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.block-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.goods {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef1f4;
}

.goods:last-child {
  border-bottom: none;
}

.goods image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 6rpx;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  line-height: 1.35;
}

.goods-total {
  color: #ef6c2f;
  font-weight: 700;
}

.total {
  margin-top: 16rpx;
  color: #ef6c2f;
  font-weight: 800;
}

.remark {
  margin-top: 18rpx;
}
