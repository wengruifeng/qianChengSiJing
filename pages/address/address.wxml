<view class="page address-page">
  <view class="card addr" wx:for="{{addresses}}" wx:key="id" bindtap="choose" data-id="{{item.id}}">
    <view class="between">
      <view class="name">{{item.contactName}} {{item.phone}}</view>
      <view class="tag" wx:if="{{item.isDefault}}">默认</view>
    </view>
    <view class="muted">{{item.region}} {{item.detail}}</view>
    <view class="addr-actions" wx:if="{{mode !== 'choose'}}">
      <view class="addr-action" catchtap="editAddress" data-id="{{item.id}}">编辑</view>
      <view class="addr-action {{item.isDefault ? 'disabled' : ''}}" catchtap="markDefault" data-id="{{item.id}}">{{item.isDefault ? '已默认' : '设为默认'}}</view>
      <view class="addr-action danger" catchtap="removeAddress" data-id="{{item.id}}">删除</view>
    </view>
  </view>
  <empty wx:if="{{addresses.length === 0}}" title="暂无地址" />
  <button class="btn-primary" bindtap="openCreate">新增地址</button>
</view>
