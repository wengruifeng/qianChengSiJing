<view class="page address-page">
  <view class="card addr" wx:for="{{addresses}}" wx:key="id" bindtap="choose" data-id="{{item.id}}">
    <view class="between">
      <view class="name">{{item.contactName}} {{item.phone}}</view>
      <view class="tag" wx:if="{{item.isDefault}}">默认</view>
    </view>
    <view class="muted">{{item.region}} {{item.detail}}</view>
  </view>
  <empty wx:if="{{addresses.length === 0}}" title="暂无地址" />
  <view class="form-card edit">
    <view class="form-row">
      <view class="form-label">联系人/店铺</view>
      <input class="form-input" value="{{form.contactName}}" bindinput="onInput" data-key="contactName" placeholder="请输入" />
    </view>
    <view class="form-row">
      <view class="form-label">手机号</view>
      <input class="form-input" value="{{form.phone}}" bindinput="onInput" data-key="phone" placeholder="请输入" />
    </view>
    <view class="form-row">
      <view class="form-label">所在地区</view>
      <input class="form-input" value="{{form.region}}" bindinput="onInput" data-key="region" placeholder="请输入" />
    </view>
    <view class="form-row">
      <view class="form-label">详细地址</view>
      <input class="form-input" value="{{form.detail}}" bindinput="onInput" data-key="detail" placeholder="请输入" />
    </view>
  </view>
  <button class="btn-primary" bindtap="save">保存地址</button>
</view>
