.home {
  padding-bottom: 126rpx;
  background: #edf4fb;
}

.top {
  padding: 18rpx 24rpx;
  background: #dff1ff;
}

.search {
  height: 82rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-radius: 40rpx;
  background: #ffffff;
  font-size: 30rpx;
}

.search-icon {
  font-size: 42rpx;
  color: #606a76;
}

.scan-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  margin-left: auto;
}

.scan-icon::before,
.scan-icon::after,
.scan-core::before,
.scan-core::after {
  content: "";
  position: absolute;
  width: 13rpx;
  height: 13rpx;
  border-color: #111827;
  border-style: solid;
  border-radius: 5rpx;
}

.scan-icon::before {
  left: 2rpx;
  top: 2rpx;
  border-width: 4rpx 0 0 4rpx;
  border-bottom-right-radius: 0;
}

.scan-icon::after {
  right: 2rpx;
  top: 2rpx;
  border-width: 4rpx 4rpx 0 0;
  border-bottom-left-radius: 0;
}

.scan-core::before {
  left: 2rpx;
  bottom: 2rpx;
  border-width: 0 0 4rpx 4rpx;
  border-top-right-radius: 0;
}

.scan-core::after {
  right: 2rpx;
  bottom: 2rpx;
  border-width: 0 4rpx 4rpx 0;
  border-top-left-radius: 0;
}

.scan-core {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(#111827, #111827) center center / 10rpx 4rpx no-repeat;
}

.hero {
  position: relative;
  height: 360rpx;
  background: #ffffff;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  opacity: 0.16;
}

.hero-text {
  position: absolute;
  right: 38rpx;
  top: 72rpx;
  text-align: right;
  color: #123e87;
}

.hero-brand {
  font-size: 34rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 36rpx;
  font-size: 52rpx;
  font-weight: 800;
}

.hero-phone {
  margin-top: 44rpx;
  font-size: 22rpx;
  letter-spacing: 0;
}

.notice {
  height: 72rpx;
  overflow: hidden;
  position: relative;
  background: #fff7e7;
  color: #e4a33a;
}

.notice-track {
  position: absolute;
  left: 0;
  top: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding-left: 100%;
  white-space: nowrap;
  animation: noticeMarquee 14s linear infinite;
}

@keyframes noticeMarquee {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(-100%);
  }
}

.cat-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 22rpx 0;
  padding: 28rpx 12rpx 34rpx;
  background: #ffffff;
}

.cat-item {
  text-align: center;
  font-size: 30rpx;
}

.cat-img {
  width: 86rpx;
  height: 86rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  line-height: 86rpx;
  background: #e8f5ed;
  color: #148642;
  font-weight: 700;
}

.topic {
  height: 260rpx;
  background: #0b52aa;
  color: #f5fbff;
  overflow: hidden;
}

.topic image {
  width: 100%;
}

.section {
  margin-top: 20rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 20rpx 4rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-sub {
  font-size: 22rpx;
  color: #8a94a3;
}

.products {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.product-card {
  overflow: hidden;
  border-radius: 8rpx;
  background: #ffffff;
}

.product-card image {
  width: 100%;
  height: 250rpx;
  background: #edf1f5;
}

.product-info {
  padding: 18rpx;
}

.product-name {
  min-height: 76rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.35;
}

.price {
  margin-top: 12rpx;
  color: #ef6c2f;
  font-size: 30rpx;
  font-weight: 700;
}

.price-hidden {
  margin-top: 12rpx;
  font-size: 30rpx;
}

.stock-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.sold-out {
  color: #dc2626;
}

.low-stock {
  color: #d97706;
}

.price-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 96rpx;
  padding: 14rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #dff1ff;
  color: #1288d8;
  z-index: 10;
}

.price-bar button {
  width: 180rpx;
  height: 68rpx;
  margin: 0;
  border-radius: 34rpx;
  background: #1592f5;
  color: #ffffff;
  font-size: 28rpx;
}
