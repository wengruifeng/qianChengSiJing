.apply {
  min-height: 100vh;
  padding: 120rpx 16rpx 160rpx;
  background: #edf3f9;
}

.heading {
  margin: 0 16rpx 50rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.heading text {
  display: block;
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 400;
}

.status {
  margin: 28rpx 16rpx;
  color: #1592f5;
}

.save-address {
  margin: 28rpx 16rpx;
  background: #edf6ff;
  color: #1592f5;
}

.submit {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 34rpx;
  height: 88rpx;
  background: #1592f5;
  color: #ffffff;
}
