<view class="page address-edit-page">
  <view class="form-card">
    <view class="form-title">{{title}}</view>
    <view class="form-row">
      <view class="form-label">联系人/店铺</view>
      <input class="form-input" value="{{form.contactName}}" bindinput="onInput" data-key="contactName" placeholder="请输入" />
    </view>
    <view class="form-row">
      <view class="form-label">手机号</view>
      <input class="form-input" type="number" maxlength="11" value="{{form.phone}}" bindinput="onInput" data-key="phone" placeholder="请输入" />
    </view>
    <view class="form-row">
      <view class="form-label">所在地区</view>
      <picker mode="region" value="{{form.regionParts}}" bindchange="onRegionChange">
        <view class="form-input {{form.region ? '' : 'placeholder'}}">{{form.region || '请选择所在地区'}}</view>
      </picker>
    </view>
    <view class="form-row">
      <view class="form-label">详细地址</view>
      <input class="form-input" value="{{form.detail}}" bindinput="onInput" data-key="detail" placeholder="请输入详细地址" />
    </view>
  </view>
  <button class="btn-primary" bindtap="save" loading="{{saving}}" disabled="{{saving}}">{{saving ? '保存中...' : submitText}}</button>
</view>
